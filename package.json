{
  "name": "doc-for-agent",
  "version": "0.2.0-dev.0",
  "description": "Unified docagent product entry for npm/npx users, forwarding to the Python core runtime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timcai06/Doc-For-Agent-skill.git"
  },
  "homepage": "https://github.com/Timcai06/Doc-For-Agent-skill#readme",
  "keywords": [
    "agents",
    "documentation",
    "installer",
    "codex",
    "claude",
    "copilot"
  ],
  "bin": {
    "docagent": "doc-for-agent/installer/node/docagent.js",
