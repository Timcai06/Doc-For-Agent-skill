{
  "name": "doc-for-agent",
  "version": "0.4.0",
  "description": "Multi-agent repository documentation skill package with a CLI adapter for install, init, refresh, and doctor workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timcai06/Doc-For-Agent-skill.git"
  },
  "homepage": "https://github.com/Timcai06/Doc-For-Agent-skill#readme",
  "keywords": [
    "agents",
    "documentation",
    "skill",
    "skills",
    "multi-agent",
    "agent-native",
    "cli",
    "npx",
    "installer",
    "codex",
    "claudecode",
    "claude-code",
    "continue",
    "copilot"
  ],
  "bin": {
    "docagent": "doc-for-agent/installer/node/docagent.js",
    "doc-for-agent": "doc-for-agent/installer/node/docagent.js"
  },
  "files": [
    "doc-for-agent/SKILL.md",
    "doc-for-agent/installer/node",
    "doc-for-agent/installer/assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "python3 doc-for-agent/installer/sync_assets.py",
    "pack:dry-run": "npm pack --dry-run",
    "quickstart": "node doc-for-agent/installer/node/docagent.js quickstart",
    "init:all": "node doc-for-agent/installer/node/docagent.js init --ai all",
    "refresh:agent": "node doc-for-agent/installer/node/docagent.js refresh --output-mode agent",
    "help": "node doc-for-agent/installer/node/docagent.js --help"
  },
  "engines": {
    "node": ">=18"
  }
}
